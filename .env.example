# EcomMarj Production Environment Variables Template

# ========================
# 1. Django Setup
# ========================
# Set to False in production
DJANGO_DEBUG=False
# Generate a new long random string for production
SECRET_KEY=yeni_uzun_ve_karmasik_bir_sifre_uretip_buraya_yazin
# Your prod domains (comma separated)
ALLOWED_HOSTS=ecommarj.com,www.ecommarj.com,api.ecommarj.com,localhost,127.0.0.1
# Allowed Origins for frontend Next.js queries
CORS_ALLOWED_ORIGINS=https://ecommarj.com,https://www.ecommarj.com,http://localhost:3000

# ========================
# 2. Database (PostgreSQL)
# ========================
POSTGRES_DB=ecompro
POSTGRES_USER=ecompro_user
POSTGRES_PASSWORD=cok_guclu_bir_veritabani_sifresi
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ========================
# 3. Redis & Celery
# ========================
REDIS_URL=redis://redis:6379/1

# ========================
# 4. Superuser Automation
# ========================
# These will be automatically created on first startup by entrypoint.sh 
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@ecommarj.local
DJANGO_SUPERUSER_PASSWORD=cok_guclu_bir_admin_sifresi

# ========================
# 5. Frontend & Security
# ========================
# The public API URL your frontend fetches from
NEXT_PUBLIC_API_URL=https://ecommarj.com/api

# Trendyol encryption keys (Optional but recommended to change in production)
ENCRYPTION_KEY=sV8Hl0a3D6R3XfJ9q2VwZsKMnC0l9Y6pT3rQ7x0N1bM=
