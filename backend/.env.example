# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=ecompro
POSTGRES_USER=ecompro_user
POSTGRES_PASSWORD=ecompro_pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Django Superuser (otomatik oluşturulur)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin123
DJANGO_SUPERUSER_EMAIL=admin@ecompro.local

# Trendyol API (Satıcı Paneli'nden alınır)
TRENDYOL_API_KEY=
TRENDYOL_API_SECRET=
TRENDYOL_SUPPLIER_ID=

# Email — OTP gönderimleri için Gmail SMTP
# Gmail App Password: myaccount.google.com/apppasswords
EMAIL_BACKEND=ecommarj_backend.email_backend.CertifiEmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=destek@ecommarj.com
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=EcomMarj <destek@ecommarj.com>

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
