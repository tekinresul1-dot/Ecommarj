# ========================
# Staging Environment
# Kopyala: cp .env.staging.example .env.staging
# ========================

DJANGO_DEBUG=False
DJANGO_SECRET_KEY=staging_icin_farkli_uzun_bir_secret_key_gir
DJANGO_ALLOWED_HOSTS=staging.ecommarj.com,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://staging.ecommarj.com,http://localhost:3000
CSRF_TRUSTED_ORIGINS=https://staging.ecommarj.com,http://localhost:3000

# Database — production'dan AYRI bir DB kullan
POSTGRES_DB=ecompro_staging
POSTGRES_USER=ecompro_staging_user
POSTGRES_PASSWORD=staging_icin_guclu_bir_sifre
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/2

# Superuser
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@ecommarj.local
DJANGO_SUPERUSER_PASSWORD=staging_admin_sifresi

# Frontend
NEXT_PUBLIC_API_URL=https://staging.ecommarj.com/api

# Encryption
ENCRYPTION_KEY=staging_icin_farkli_bir_encryption_key_uret

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
